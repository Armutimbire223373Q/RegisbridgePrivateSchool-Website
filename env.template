# Django
DJANGO_SETTINGS_MODULE=regisbridge.settings.production
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False

# Database
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@regisbridge.com

# AWS
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Redis & Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Security
ALLOWED_HOSTS=regisbridge.com,www.regisbridge.com
CORS_ALLOWED_ORIGINS=https://regisbridge.com,https://www.regisbridge.com

# Sentry
SENTRY_DSN=your-sentry-dsn

# Other Services (if needed)
# STRIPE_PUBLIC_KEY=your-stripe-public-key
# STRIPE_SECRET_KEY=your-stripe-secret-key
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key 